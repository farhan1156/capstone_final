    "\n",
    "\n",
    "driver_X = pd.get_dummies(class_df[reg_features], drop_first=True)\n",
    "driver_y = class_df['Driver_Availability'].map({'Online':1, 'Offline':0})\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(driver_X, driver_y, test_size=0.2, random_state=42)\n",
    "\n",
    "driver_classifier = RandomForestClassifier(n_estimators=100, random_state=42)\n",
    "driver_classifier.fit(X_train, y_train)\n",
    "\n",
    "y_pred = driver_classifier.predict(X_test)\n",
    "\n",
    "dc_acc = accuracy_score(y_test, y_pred)\n",
    "rscore = recall_score(y_test, y_pred)\n",
