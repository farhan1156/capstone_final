    "# Order Time and Delivery time contains date, time and hours information\n",
    "# convert it into three columns Order_Time, Order_Hour and Order_DayofWeek\n",
    "\n",
    "fe_df['Order_Time'] = pd.to_datetime(fe_df['Order_Time'])\n",
    "fe_df['Order_Hour'] = fe_df['Order_Time'].dt.hour\n",
    "fe_df['Order_DayofWeek'] = fe_df['Order_Time'].dt.dayofweek\n",
    "\n",
    "fe_df['Delivery_Time'] = pd.to_datetime(fe_df['Delivery_Time'])\n",
    "fe_df['Delivery_hour'] = fe_df['Delivery_Time'].dt.hour\n",
    "fe_df['Delivery_DayofWeek'] = fe_df['Delivery_Time'].dt.dayofweek\n",
    "\n",
    "#Encoding categorical variables\n",
    "fe_df = pd.get_dummies(fe_df, columns=['Payment_Method', 'Order_Status', 'Driver_Vehicle', 'Traffic_Level','Driver_Availability', 'City'], drop_first=True)\n",
    "\n",
    "# Dropping the columns which will not effect our output, like user id, order id, driver id and restaurant id will not\n",
    "# effect the delivery time, so we can drop them\n",
    "fe_df.drop(['User_ID', 'Order_ID', 'Driver_ID', 'Restaurant_ID','Item_Name','Order_Time','Delivery_Time'], axis=1, inplace=True)\n",
    "fe_df.head()\n"
   ]
