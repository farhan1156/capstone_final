   "source": [
    "# Removing outliers using Isolation Forest\n",
    "# https://scikit-learn.org/stable/modules/generated/sklearn.ensemble.IsolationForest.html\n",
    "\n",
    "\n",
    "numeric_cols = df_clean.select_dtypes(include=[np.number]).columns\n",
    "iso_forest = IsolationForest(contamination=0.05, random_state=42)\n",
    "outliers_predictions = iso_forest.fit_predict(df_clean[numeric_cols])\n",
    "df_clean['outliers'] = outliers_predictions\n",
    "\n",
    "sns.pairplot(df_clean[numeric_cols].assign(outliers=df_clean['outliers']), hue='outliers',palette='Set1')\n",
    "plt.suptitle('Outlier Aanalysis using Isolation Forest', y=1.02)\n",
    "#plt.savefig('img/outlier_analysis_pairplot.png')\n",
    "\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "print(f\"Number of outliers detected: {(df_clean['outliers'] == -1).sum()}\")\n"
   ]
  },
